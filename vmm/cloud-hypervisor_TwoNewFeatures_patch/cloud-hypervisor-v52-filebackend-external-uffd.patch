+    #[allow(unused)]
+    fn drain_fault_batch(&mut self) -> Result<Vec<PendingFault>> {
+        let mut out = Vec::with_capacity(64);
+
+        loop {
+            let msg = match read_pagefault_message(self.uffd_fd) {
+                Ok(msg) => msg,
+                Err(e) => {
+                    if e.kind() == std::io::ErrorKind::WouldBlock {
+                        break;
+                    }
+                    if e.kind() == std::io::ErrorKind::Interrupted {
+                        continue;
+                    }
+                    return Err(anyhow::Error::new(e).context("read uffd_msg failed"));
+                }
+            };
+
+            debug!(
+                "[handler] msg.event = {} pf_flags=0x{:x} pf_address=0x{:x}",
+                msg.event, msg.pf_flags, msg.pf_address
+            );
+
+            if msg.event != EXTERNAL_UFFD_EVENT_PAGEFAULT {
+                debug!("[handler] skipping non-pagefault event {}", msg.event);
+                continue;
+            }
+
+            let addr = msg.pf_address as u64;
+
+            let idx = match self.find_mapping_idx(addr) {
+                Ok(idx) => idx,
+                Err(e) => {
+                    debug!("[handler] mapping miss for addr=0x{addr:x}: {e:#}");
+                    continue;
+                }
+            };
+
+            self.stats[idx].fault_count += 1;
+
+            out.push(PendingFault {
+                addr,
+                mapping_idx: idx,
+            });
+
+            if out.len() >= 64 {
+                break;
+            }
+        }
+
+        out.sort_by_key(|f| (f.mapping_idx, f.addr));
+        Ok(out)
+    }
