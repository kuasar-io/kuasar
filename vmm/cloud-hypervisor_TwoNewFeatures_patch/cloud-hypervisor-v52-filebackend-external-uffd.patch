+    // help function - For external UFFD (lazy loading) restore
+    fn find_mapping_idx(&self, addr: u64) -> Result<usize> {
+        for (idx, m) in self.mappings.iter().enumerate() {
+            let start = m.base_host_virt_addr;
+            let end = m.base_host_virt_addr + m.size;
+
+            if addr >= start && addr < end {
+                return Ok(idx);
+            }
+        }
+
+        Err(anyhow::anyhow!("address 0x{addr:x} not found in mappings"))
+    }
