+// change - for external UFFD (lazy loading) restore
+struct SnapshotMap {
+    ptr: *mut c_void,
+    len: usize,
+}
+
+// change - for external UFFD (lazy loading) restore
+impl SnapshotMap {
+    pub fn read_exact_at(&self, offset: u64, buf: &mut [u8]) -> io::Result<()> {
+        let start = usize::try_from(offset).map_err(|_| {
+            Error::new(
+                ErrorKind::InvalidInput,
+                format!("offset {offset} does not fit in usize"),
+            )
+        })?;
+
+        let end = start.checked_add(buf.len()).ok_or_else(|| {
+            Error::new(
+                ErrorKind::InvalidInput,
+                format!("offset {} + len {} overflow", offset, buf.len()),
+            )
+        })?;
+
+        if end > self.len {
+            return Err(Error::new(
+                ErrorKind::UnexpectedEof,
+                format!(
+                    "snapshot out of range: [{}..{}) exceeds snapshot len {}",
+                    start, end, self.len
+                ),
+            ));
+        }
+
+        // SAFETY: 
+        // - self.ptr points to a valid mapped memory region of length self.len
+        // - range [start, end) has been bounds-checked above
+        // - buf is a valid writable slice of length buf.len()
+        unsafe {
+            std::ptr::copy_nonoverlapping(
+                (self.ptr as *const u8).add(start),
+                buf.as_mut_ptr(),
+                buf.len(),
+            );
+        }
+
+        Ok(())
+    }
+
+    fn map(file: &File) -> Result<Self> {
+        let len = file.metadata()?.len() as usize;
+        // SAFETY: 
+        // `mmap` is called with a valid file descriptor, a null hint address, read-only
+        // protection, and MAP_PRIVATE. The requested length `len` is the file-backed
+        // mapping size expected by the caller. No Rust references are created here;
+        // the returned pointer is checked against MAP_FAILED before use and must be
+        // unmapped with `munmap` when no longer needed.
+        let ptr = unsafe { 
+            mmap(
+                ptr::null_mut(), 
+                len, 
+                PROT_READ,
+                MAP_PRIVATE, 
+                file.as_raw_fd(), 
+                0) };
+        
+        if ptr == MAP_FAILED {
+            return Err(io::Error::last_os_error()).context("mmap snapshot failed");
+        }
+
+        // SAFETY: 
+        // `ptr` points to a valid memory region previously returned by `mmap`,
+        // and `len` is the exact length of that mapping. The region remains
+        // mapped for the duration of this call. `madvise` does not dereference
+        // pointers in Rust terms; it only provides a hint to the kernel and
+        // does not violate Rust's aliasing or memory safety guarantees.
+        //
+        // Errors from madvise are ignored as it is only a performance hint.
+        unsafe {
+            let _ = madvise(ptr, len, MADV_WILLNEED);
+        }
+
+        Ok(Self { ptr, len })
+    }
+
+    fn as_ptr(&self) -> *const u8 {
+        self.ptr as *const u8
+    }
+}
