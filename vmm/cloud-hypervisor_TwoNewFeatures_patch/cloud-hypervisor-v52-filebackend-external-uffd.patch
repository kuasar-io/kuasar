+// Change - For external UFFD (lazy loading) restore
+#[allow(unused)]
+fn recv_fd(sock: RawFd) -> Result<(Vec<u8>, RawFd)> {
+    let mut buf = [0u8; 16 * 1024];
+    let mut iov = [iovec {
+        iov_base: buf.as_mut_ptr() as *mut c_void,
+        iov_len: buf.len(),
+    }];
+
+    let mut cmsgspace = [0u8; 64];
+
+    let mut msg: msghdr =
+        // SAFETY: 
+        // `msghdr` is a C struct without invalid zero bit patterns (no Rust references
+        // or NonZero types). Zero-initialization is valid. All required fields are
+        // initialized before the struct is used in a system call.
+        unsafe { mem::zeroed() };
+    msg.msg_iov = iov.as_mut_ptr();
+    msg.msg_iovlen = 1;
+    msg.msg_control = cmsgspace.as_mut_ptr() as *mut c_void;
+    msg.msg_controllen = cmsgspace.len();
+
+    let size = 
+        // SAFETY: 
+        // `recvmsg` is invoked with a valid socket descriptor and a properly
+        // initialized `msghdr`. All buffers referenced by `msg_iov` and
+        // `msg_control` are valid and writable for their specified lengths.
+        // The kernel writes only within these bounds, and no Rust aliasing rules
+        // are violated. The return value is the number of bytes received or a
+        // negative error code.
+        unsafe { recvmsg(sock, &mut msg, 0) };
+    if size <= 0 {
+        return Err(io::Error::last_os_error()).context("recvmsg failed");
+    }
+
+    let mut fd = -1;
+    // SAFETY: 
+    // `msg` was filled by a successful `recvmsg` call with a control buffer large
+    // enough to hold the expected SCM_RIGHTS control message. `CMSG_FIRSTHDR` may
+    // return null, which is checked before use. When non-null, `CMSG_DATA(cmsg)`
+    // points to the ancillary data owned by `msg`, and we read exactly one RawFd
+    // that was sent by the peer.
+    unsafe {
+        let cmsg = CMSG_FIRSTHDR(&msg);
+        if !cmsg.is_null() {
+            let data = CMSG_DATA(cmsg) as *const RawFd;
+            fd = *data;
+        }
+    }
+
+    Ok((buf[..size as usize].to_vec(), fd))
+}
