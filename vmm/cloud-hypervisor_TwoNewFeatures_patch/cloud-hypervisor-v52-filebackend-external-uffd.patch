+
+// Change - For optimization of external UFFD by focusing on 
+// batching, merging and prefetching
+impl MappingHeuristics {
+    #[allow(unused)]
+    fn observe_fault(&mut self, addr: u64, page_size: u64) {
+        if self.last_fault_addr != 0 && addr == self.last_fault_end {
+            self.sequential_hits += 1;
+        } else {
+            self.random_hits += 1;
+            self.sequential_hits = 0;
+        }
+
+        self.last_fault_addr = addr;
+        self.last_fault_end = addr + page_size;
+
+        if self.current_prefetch_pages == 0 {
+            self.current_prefetch_pages = DEFAULT_PREFETCH_PAGES;
+        }
+
+        if self.sequential_hits >= SEQUENTIAL_PROMOTE_THRESHOLD {
+            self.current_prefetch_pages =
+                (self.current_prefetch_pages.saturating_mul(2)).min(MAX_PREFETCH_PAGES);
+        } else if self.random_hits > self.sequential_hits + 4 {
+            self.current_prefetch_pages =
+                (self.current_prefetch_pages / 2).max(1);
+        }
+    }
+
+    #[allow(unused)]
+    fn suggested_prefetch_pages(&self) -> u64 {
+        self.current_prefetch_pages.max(1)
+
