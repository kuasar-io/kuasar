+    // change - for external UFFD (lazy loading) restore
+    #[allow(unused)]
+    fn coalesce_and_copy(&mut self, faults: &[PendingFault]) -> Result<()> {
+        
+        self.handler_stats.batch_count += 1;
+        self.handler_stats.drained_faults_total += faults.len() as u64;
+        
+        let mut i = 0;
+
+        while i < faults.len() {
+            let idx = faults[i].mapping_idx;
+
+            let base_host_virt_addr = self.mappings[idx].base_host_virt_addr;
+            let mapping_size = self.mappings[idx].size;
+            let mapping_offset = self.mappings[idx].offset;
+            let page = self.mappings[idx].page_size;
+
+            let start_addr = align_down(faults[i].addr, page);
+            let mut end_addr = start_addr + page;
+
+            let mut j = i + 1;
+
+            while j < faults.len() && faults[j].mapping_idx == idx {
+                let next = align_down(faults[j].addr, page);
+                if next <= end_addr + 2 * page {
+                    end_addr = std::cmp::max(end_addr, next + page);
+                    j += 1;
+                } else {
+                    break;
+                }
+            }
+
+            let extra_pages = self.choose_prefetch_pages(idx, start_addr);
+            let desired_end = end_addr + extra_pages * page;
+
+            let region_end = base_host_virt_addr + mapping_size;
+            let final_end = std::cmp::min(desired_end, region_end);
+            let len = final_end - start_addr;
+
+            let fault_pages = (end_addr - start_addr) / page;
+            let total_pages = len / page;
+            let prefetch_pages = total_pages.saturating_sub(fault_pages);
+
+            eprintln!(
+                "[handler] coalesced copy: idx={idx} start=0x{start_addr:x} end=0x{final_end:x} len=0x{len:x} fault_pages={fault_pages} total_pages={total_pages} prefetch_pages={prefetch_pages}",
+            );
+
+            if prefetch_pages > 0 {
+                self.handler_stats.prefetch_pages += prefetch_pages;
+                self.handler_stats.sequential_hits += 1;
+
+                self.stats[idx].prefetch_pages += prefetch_pages;
+                self.stats[idx].sequential_hits += 1;
+            }
+
+            let src_off = mapping_offset + (start_addr - base_host_virt_addr);
+
+            let src =
+                // SAFETY: 
+                // src_off is derived from a validated mapping and snapshot mmap.
+                unsafe {
+                    self.snapshot.as_ptr().add(src_off as usize)
+                };
+
+            eprintln!(
+                "[handler] coalesced copy: mapping_idx={idx} start=0x{start_addr:x} end=0x{final_end:x} src_off=0x{src_off:x} len=0x{len:x} extra_pages={extra_pages}",
+            );
+
+            let copy_stats = self.copy_range(
+                start_addr,
+                src as u64,
+                len as u64,
+                self.mappings[idx].page_size,
+            )?;
+
+            match copy_stats.outcome {
+                CopyOutcome::Full => {}
+
+                CopyOutcome::EagainRetry => {
+                    self.handler_stats.copy_eagain_retries += copy_stats.eagain_retries.max(1);
+                    self.stats[idx].eagain_retries += copy_stats.eagain_retries.max(1);
+                }
+
+                CopyOutcome::Fallback => {
+                    self.handler_stats.copy_eexist_fallbacks += 1;
+                    self.stats[idx].eexist_fallbacks += 1;
+
+                    self.handler_stats.copy_eagain_retries += copy_stats.eagain_retries;
+                    self.stats[idx].eagain_retries += copy_stats.eagain_retries;
+                }
+            }
+
+            // ===== global stats =====
+            self.handler_stats.copied_pages += copy_stats.copied_pages;
+            self.handler_stats.copied_bytes += copy_stats.copied_pages * page;
+            self.handler_stats.copy_eagain_retries += 0; // 已在上面处理
+            self.handler_stats.copy_eexist_fallbacks += 0; // 已在上面处理
+
+            self.handler_stats.range_copy_calls += copy_stats.range_copy_calls;
+            self.handler_stats.page_copy_calls += copy_stats.page_copy_calls;
+            self.handler_stats.skipped_existing_pages += copy_stats.skipped_existing_pages;
+
+            // ===== per-region stats =====
+            self.stats[idx].copied_pages += copy_stats.copied_pages;
+            self.stats[idx].copied_bytes += copy_stats.copied_pages * page;
+
+            // legacy stats（保持兼容）
+            self.stats[idx].copy_calls += copy_stats.range_copy_calls + copy_stats.page_copy_calls;
+            self.stats[idx].pages_copied += copy_stats.copied_pages;
+
+            let h = &mut self.heuristics[idx];
+            h.last_fault_addr = start_addr;
+            h.last_prefetch_end = final_end;
+
+            i = j;
+        }
+
+        Ok(())
+    }
