+    // change - For external UFFD (lazy loading) restore
+    #[allow(unused)]
+    fn handle_remove_event(&mut self, start: u64, end: u64) -> Result<()> {
+        for (idx, m) in self.mappings.iter().enumerate() {
+            let m_start = m.base_host_virt_addr;
+            let m_end = m.base_host_virt_addr + m.size;
+            let ov_start = max(start, m_start);
+            let ov_end = min(end, m_end);
+
+            if ov_start < ov_end {
+                let aligned_s = align_down(ov_start, m.page_size);
+                let aligned_e = align_up(ov_end, m.page_size);
+                self.zeropage_range(aligned_s, aligned_e - aligned_s)?;
+                self.stats[idx].remove_events += 1;
+                self.stats[idx].zeropage_calls += 1;
+            }
+        }
+
+        Ok(())
+    }
