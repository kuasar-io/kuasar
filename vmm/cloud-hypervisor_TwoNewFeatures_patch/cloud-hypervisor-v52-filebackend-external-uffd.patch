+// 6. handler runtime（真正执行层)
+// ======================
+// handler runtime
+// ======================
+#[derive(Debug, Clone, Copy)]
+pub struct FaultEvent {
+    pub fault_addr: u64,
+    pub flags: u64,
+}
+
+pub struct ExternalUffdContext {
+    pub uffd_fd: RawFd,
+    pub snapshot_file: File,
+    pub region_table: RegionTable,
+}
+
+// 7. help function
+pub struct UffdPagefaultMsg {
+    pub event: u8,
+    pub pf_flags: u64,
+    pub pf_address: u64,
+}
+
+pub fn read_pagefault_message(fd: RawFd) -> io::Result<UffdPagefaultMsg> {
+    let mut msg: crate::uffd::UffdMsg =
+        // SAFETY: `UffdMsg` is a plain C-compatible struct used for reading one
+        // pagefault message from userfaultfd.
+        unsafe {
+            // SAFETY: `UffdMsg` is a plain C-compatible struct used for reading one
+            // pagefault message from userfaultfd.
+            std::mem::zeroed()
+        };
+
+    let r = 
+        // SAFETY: `fd` is expected to be a valid userfaultfd, and `msg`
+        // points to writable memory large enough for one `UffdMsg`.
+        unsafe {
+            libc::read(
+                fd,
+                &mut msg as *mut _ as *mut libc::c_void,
+                std::mem::size_of::<crate::uffd::UffdMsg>(),
+            )
+    };
+
+    if r < 0 {
+        return Err(std::io::Error::last_os_error());
+    }
+
+    if r == 0 {
+        return Err(std::io::Error::other("read returned EOF on uffd"));
+    }
+
+    if r as usize != std::mem::size_of::<crate::uffd::UffdMsg>() {
+        return Err(std::io::Error::other(format!(
+            "short read on uffd msg: got {}, expected {}",
+            r,
+            std::mem::size_of::<crate::uffd::UffdMsg>()
+        )));
+    }
+
+    Ok(UffdPagefaultMsg {
+        event: msg.event,
+        pf_flags: msg.pf_flags,
+        pf_address: msg.pf_address,
+    })
+}
