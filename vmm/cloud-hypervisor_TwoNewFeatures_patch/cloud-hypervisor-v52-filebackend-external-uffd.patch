+    fn resolve_file_offset_and_available(
+        &self,
+        mapping_idx: usize,
+        dst_addr: u64,
+    ) -> Result<(u64, u64)> {
+        let m = self
+            .mappings
+            .get(mapping_idx)
+            .with_context(|| format!("invalid mapping_idx {mapping_idx}"))?;
+
+        let start = m.base_host_virt_addr;
+        let end = start
+            .checked_add(m.size)
+            .with_context(|| format!("mapping[{mapping_idx}] end overflow"))?;
+
+        if dst_addr < start || dst_addr >= end {
+            bail!(
+                "dst_addr 0x{dst_addr:x} out of mapping[{mapping_idx}] range [0x{start:x}, 0x{end:x})",
+            );
+        }
+
+        let rel = dst_addr - start;
+        let file_offset = m.offset
+            .checked_add(rel)
+            .with_context(|| format!("file offset overflow for mapping {mapping_idx}"))?;
+        let available = end - dst_addr;
+
+        Ok((file_offset, available))
+    }
+
+    fn read_snapshot_exact(&mut self, src_offset: u64, len: usize) -> io::Result<&[u8]> {
+        if self.scratch.len() < len {
+            self.scratch.resize(len, 0);
+        }
+
+        let buf = &mut self.scratch[..len];
+        self.snapshot.read_exact_at(src_offset, buf)?;
+        Ok(buf)
+    }
+
+    fn do_uffd_copy(
+        &mut self,
+        dst_addr: u64,
+        src_offset: u64,
+        len: usize,
+        page_size: u64,
+    ) -> io::Result<()> {
+        if len == 0 {
+            return Ok(());
+        }
+
+        if !dst_addr.is_multiple_of(page_size) {
+            return Err(Error::new(
+                ErrorKind::InvalidInput,
+                format!(
+                    "dst_addr 0x{dst_addr:x} is not aligned to page_size {page_size}"
+                ),
+            ));
+        }
+
+        if !src_offset.is_multiple_of(page_size) {    
+            return Err(Error::new(
+                ErrorKind::InvalidInput,
+                format!(
+                    "src_offset 0x{src_offset:x} is not aligned to page_size {page_size}"
+                ),
+            ));
+        }
+
+        if !(len as u64).is_multiple_of(page_size) {
+            return Err(Error::new(
+                ErrorKind::InvalidInput,
+                format!("len {len} is not aligned to page_size {page_size}"),
+            ));
+        }
+
+        let src_buf = self.read_snapshot_exact(src_offset, len)?;
+
+        let mut copy = uffdio_copy {
+            dst: dst_addr,
+            src: src_buf.as_ptr() as u64,
+            len: len as u64,
+            mode: 0,
+            copy: 0,
+        };
+
+        // SAFETY: 
+        // `self.uffd_fd` is a valid userfaultfd file descriptor. `copy` is a properly
+        // initialized `uffdio_copy` structure whose dst/src/len fields describe valid,
+        // page-aligned memory ranges prepared by the handler. Passing `&mut copy` is
+        // safe because the kernel may update result fields in the structure, and the
+        // structure remains alive for the duration of the ioctl call.
+        let ret = unsafe { libc::ioctl(self.uffd_fd, UFFDIO_COPY as _, &mut copy) };
+        if ret == -1 {
+            return Err(io::Error::last_os_error());
+        }
+
+        if copy.copy < 0 {
+            return Err(io::Error::from_raw_os_error((-copy.copy) as i32));
+        }
+
+        if copy.copy as usize != len {
+            return Err(std::io::Error::other(
+                format!(
+                    "UFFDIO_COPY short copy: expected {} bytes, copied {}",
+                    len, copy.copy
+                ),
+            ));
+        }
+
+        Ok(())
+    }
+
+    fn uffd_copy_once(
+        &mut self,
+        dst_addr: u64,
+        src_offset: u64,
+        len: usize,
+        mapping_idx: usize,
+        page_size: u64,
+    ) -> Result<(), CopyError> {
+        match self.do_uffd_copy(dst_addr, src_offset, len, page_size) {
+            Ok(()) => Ok(()),
+            Err(e) => {
+                if let Some(raw) = e.raw_os_error() {
+                    match raw {
+                        libc::EAGAIN => {
+                            self.stats[mapping_idx].eagain_retries += 1;
+                            self.handler_stats.copy_eagain_retries += 1;
+                            Err(CopyError::TryAgain)
+                        }
+                        libc::EEXIST => {
+                            self.stats[mapping_idx].eexist_fallbacks += 1;
+                            self.handler_stats.copy_eexist_fallbacks += 1;
+                            self.stats[mapping_idx].skipped_existing_pages +=
+                                (len as u64) / page_size;
+                            self.handler_stats.skipped_existing_pages +=
+                                (len as u64) / page_size;
+                            Err(CopyError::AlreadyExists)
+                        }
+                        _ => Err(CopyError::Fatal(e.into())),
+                    }
+                } else {
+                    Err(CopyError::Fatal(e.into()))
+                }
+            }
+        }
+    }
+
+    fn read_pagefault_message_nonblocking(fd: RawFd) -> anyhow::Result<Option<UffdMsg>> {
+        // SAFETY: 
+        // `UffdMsg` is a plain data struct (repr(C)) without invalid zero bit patterns
+        // such as Rust references or NonZero types. Zero-initialization is valid for
+        // this type, and all fields are filled by the kernel (e.g., via read/recv)
+        // before being used.
+        let mut msg: UffdMsg = unsafe { std::mem::zeroed() };
+
+        // SAFETY: 
+        // `fd` is a valid userfaultfd file descriptor. `msg` points to a valid,
+        // writable `UffdMsg` buffer, and the provided length is exactly the size of
+        // that buffer. The kernel writes at most this many bytes into `msg`, which
+        // remains alive for the duration of the call.
+        let nread = unsafe {
+            libc::read(
+                fd,
+                &mut msg as *mut _ as *mut libc::c_void,
+                std::mem::size_of::<UffdMsg>(),
+            )
+        };
+
+        if nread == std::mem::size_of::<UffdMsg>() as isize {
+            return Ok(Some(msg));
+        }
+
+        if nread < 0 {
+            let err = std::io::Error::last_os_error();
+            match err.raw_os_error() {
+                #[allow(unused)]
+                Some(libc::EAGAIN) | Some(libc::EWOULDBLOCK) => return Ok(None),
+                _ => return Err(err.into()),
+            }
+        }
+
+        bail!(
+            "short read from userfaultfd: expected {} bytes, got {}",
+            std::mem::size_of::<UffdMsg>(),
+            nread
+        );
+    }
+
+    // For optimization of external UFFD by focusing on 
+    // batching, merging and prefetching
+    fn read_one_fault_nonblocking(&mut self) -> Result<Option<PendingFault>> {
+        let msg = match Self::read_pagefault_message_nonblocking(self.uffd_fd)? {
+            Some(msg) => msg,
+            None => return Ok(None),
+        };
+
+        if msg.event != EXTERNAL_UFFD_EVENT_PAGEFAULT {
+            bail!("unexpected uffd event {}", msg.event);
+        }
+
+        let addr = msg.pf_address;
+
+        let (mapping_idx, _) = self
+            .find_mapping_by_addr(addr)
+            .with_context(|| format!("address 0x{addr:x} not found in mappings"))?;
+
+        self.stats[mapping_idx].fault_count += 1;
+        self.handler_stats.fault_count += 1;
+
+        // 新增：如果这个 fault 落在最近 prefetch window 内，则记 useful
+        self.record_prefetch_hit_if_any(mapping_idx, addr);
+
+        Ok(Some(PendingFault { addr, mapping_idx }))
+    }
+
+    // For optimization of external UFFD by focusing on 
+    // batching, merging and prefetching
+    fn merge_faults_into_ranges(
+        &self,
+        mut faults: Vec<PendingFault>,
+    ) -> Vec<FaultRange> {
+        if faults.is_empty() {
+            return Vec::new();
+        }
+
+        faults.sort_by_key(|f| (f.mapping_idx, f.addr));
+
+        let mut ranges = Vec::with_capacity(faults.len());
+        let mut i = 0;
+
+        while i < faults.len() {
+            let f = faults[i];
+            let page_size = self.mappings[f.mapping_idx].page_size;
+
+            //let mut start = align_down(f.addr, page_size);
+            let start = align_down(f.addr, page_size);
+            let mut end = start + page_size;
+            let mut fault_pages = 1u64;
+            let mut j = i + 1;
+
+            while j < faults.len() {
+                let next = faults[j];
+                if next.mapping_idx != f.mapping_idx {
+                    break;
+                }
+
+                let next_addr = align_down(next.addr, page_size);
+                if next_addr <= end {
+                    if next_addr + page_size > end {
+                        end = next_addr + page_size;
+                    }
+                    fault_pages += 1;
+                    j += 1;
+                } else if next_addr == end {
+                    end += page_size;
+                    fault_pages += 1;
+                    j += 1;
+                } else {
+                    break;
+                }
+            }
+
+            ranges.push(FaultRange {
+                mapping_idx: f.mapping_idx,
+                start_addr: start,
+                end_addr: end,
+                fault_pages,
+                prefetched_pages: 0,
+            });
+
+            i = j;
+        }
+
+        ranges
+    }
+
+    fn copy_range_from_snapshot(&mut self, range: &FaultRange) -> Result<()> {
+        let idx = range.mapping_idx;
+        let page_size = self.mappings[idx].page_size;
+
+        let mut dst = range.start_addr;
+        let end = range.end_addr;
+
+        self.stats[idx].range_copy_calls += 1;
+        self.handler_stats.range_copy_calls += 1;
+
+        while dst < end {
+            let (src_offset, available_in_mapping) =
+                self.resolve_file_offset_and_available(idx, dst)?;
+
+            let remaining_in_range = end - dst;
+
+            let base_len = remaining_in_range.min(available_in_mapping);
+
+            // 关键改动：
+            // 如果当前 base_len 太小，则主动扩大到一个最小 copy chunk，
+            // 但不能越过 mapping 边界，也不能超过总的 COPY_CHUNK_BYTES。
+            let desired_len = base_len.max(MIN_COPY_CHUNK_BYTES);
+
+            // 对齐到 page size，避免非页对齐 copy
+            let aligned_desired_len =
+                (desired_len / page_size) * page_size;
+
+            let chunk_len = aligned_desired_len
+                .max(page_size)
+                .min(available_in_mapping)
+                .min(COPY_CHUNK_BYTES);
+
+            let chunk_len_usize = usize::try_from(chunk_len)
+                .context("chunk length does not fit in usize")?;
+
+            let pages_in_chunk = chunk_len / page_size;
+
+            self.stats[idx].page_copy_calls += pages_in_chunk;
+            self.handler_stats.page_copy_calls += pages_in_chunk;
+
+            match self.uffd_copy_once(dst, src_offset, chunk_len_usize, idx, page_size) {
+                Ok(()) => {
+                    self.stats[idx].copy_calls += 1;
+
+                    self.stats[idx].copied_pages += pages_in_chunk;
+                    self.stats[idx].copied_bytes += chunk_len;
+
+                    self.handler_stats.copied_pages += pages_in_chunk;
+                    self.handler_stats.copied_bytes += chunk_len;
+                }
+                Err(CopyError::AlreadyExists) => {
+                    // already counted in skipped_existing_pages inside uffd_copy_once
+                }
+                Err(CopyError::TryAgain) => {
+                    match self.uffd_copy_once(dst, src_offset, chunk_len_usize, idx, page_size) {
+                        Ok(()) => {
+                            self.stats[idx].copy_calls += 1;
+
+                            self.stats[idx].copied_pages += pages_in_chunk;
+                            self.stats[idx].copied_bytes += chunk_len;
+
+                            self.handler_stats.copied_pages += pages_in_chunk;
+                            self.handler_stats.copied_bytes += chunk_len;
+                        }
+                        Err(CopyError::AlreadyExists) => {}
+                        Err(CopyError::TryAgain) => {
+                            bail!(
+                                "UFFDIO_COPY got EAGAIN twice: mapping={idx} dst=0x{dst} len={chunk_len_usize}",
+                            );
+                        }
+                        Err(CopyError::Fatal(e)) => return Err(e),
+                    }
+                }
+                Err(CopyError::Fatal(e)) => return Err(e),
+            }
+
+            // 因为这次已经主动把 [dst, dst + chunk_len) 都填进去了，
+            // 不需要只推进到 range_end，而是直接推进到本次真正 copy 的末尾
+            dst += chunk_len;
+        }
+
+        self.stats[idx].prefetch_pages += range.prefetched_pages;
+        self.handler_stats.prefetch_pages += range.prefetched_pages;
+
+        Ok(())
+    }
+
+    #[allow(unused)]
+    fn update_merge_stats(&mut self, ranges: &[FaultRange]) {
+        for range in ranges {
+            let idx = range.mapping_idx;
+            self.stats[idx].merged_ranges += 1;
+            if range.fault_pages > 1 {
+                self.stats[idx].merged_fault_savings += range.fault_pages - 1;
+            }
+        }
+    }
+
+    fn print_perf_summary_opti(&self) {
+        let avg_faults_per_batch = if self.handler_stats.batch_count > 0 {
+            self.handler_stats.drained_faults_total as f64 / self.handler_stats.batch_count as f64
+        } else {
+            0.0
+        };
+
+        let avg_pages_per_batch = if self.handler_stats.batch_count > 0 {
+            self.handler_stats.copied_pages as f64 / self.handler_stats.batch_count as f64
+        } else {
+            0.0
+        };
+
+        eprintln!(
+            "[handler][summary] avg_faults_per_batch={:.2} avg_pages_per_batch={:.2} sequential_hits={} random_hits={} max_faults_in_batch={} max_pages_in_batch={} prefetch_useful_pages={} prefetch_wasted_pages={}",
+            avg_faults_per_batch,
+            avg_pages_per_batch,
+            self.handler_stats.sequential_hits,
+            self.handler_stats.random_hits,
+            self.handler_stats.max_faults_in_batch,
+            self.handler_stats.max_pages_in_batch,
+            self.handler_stats.prefetch_useful_pages,
+            self.handler_stats.prefetch_wasted_pages,
+        );
+    }
+
+    fn choose_prefetch_pages(
+        &mut self,
+        mapping_idx: usize,
+        fault_addr: u64,
+    ) -> u64 {
+        let page_size = self.mappings[mapping_idx].page_size;
+        let heur = &mut self.heuristics[mapping_idx];
+
+        let is_sequential =
+            heur.last_fault_addr != 0 &&
+            fault_addr == heur.last_fault_addr + page_size;
+
+        if is_sequential {
+            heur.seq_hits += 1;
+
+            self.stats[mapping_idx].sequential_hits += 1;
+            self.handler_stats.sequential_hits += 1;
+        } else {
+            heur.seq_hits = 0;
+            self.handler_stats.random_hits += 1;
+        }
+
+        heur.last_fault_addr = fault_addr;
+
+        // --- 决定 prefetch 页数 ---
+        let prefetch_pages = if heur.seq_hits >= 2 {
+            2
+        } else if heur.seq_hits == 1 {
+            1
+        } else {
+            0
+        };
+
+        // Maybe try this pages of prefetch
+        //let prefetch_pages = match heur.seq_hits {
+        //    0 => 0,
+        //    1 => 1,
+        //    2 | 3 => 2,
+        //    _ => 4,
+        //};
+
+        prefetch_pages.min(MAX_PREFETCH_PAGES)
+    }
+
+    fn maybe_expand_range_with_prefetch(
+        &mut self,
+        range: &mut FaultRange,
+    ) {
+        let idx = range.mapping_idx;
+        let page_size = self.mappings[idx].page_size;
+        let mapping_end =
+            self.mappings[idx].base_host_virt_addr + self.mappings[idx].size;
+
+        let original_end = range.end_addr;
+
+        let prefetch_pages = self.choose_prefetch_pages(idx, range.start_addr);
+        if prefetch_pages == 0 {
+            return;
+        }
+
+        let mut new_end = original_end + prefetch_pages * page_size;
+        new_end = new_end.min(mapping_end);
+
+        {
+            let heur = &self.heuristics[idx];
+
+            // if the new prefetch does not extend beyond previous prefetch coverage,
+            // skip it to avoid redundant work
+            if heur.last_prefetch_end != 0 && new_end <= heur.last_prefetch_end {
+                return;
+            }
+        }
+
+        let added_pages = (new_end - original_end) / page_size;
+        if added_pages == 0 {
+            return;
+        }
+
+        // finalize previous window before opening a new one
+        self.finalize_prefetch_window(idx);
+
+        range.prefetched_pages = added_pages;
+        range.end_addr = new_end;
+
+        let heur = &mut self.heuristics[idx];
+        heur.last_prefetch_end = new_end;
+
+        // the actual prefetched portion is [original_end, new_end)
+        heur.prefetch_start = original_end;
+        heur.prefetch_end = new_end;
+        heur.prefetched_pages_outstanding = added_pages;
+    }
+
+    fn run(&mut self) -> Result<()> {
+        let stop = Arc::new(AtomicBool::new(false));
+        let stop_flag = Arc::clone(&stop);
+
+        ctrlc::set_handler(move || {
+            eprintln!("\n[handler] Ctrl+C received, stopping...");
+            stop_flag.store(true, Ordering::SeqCst);
+        })
+        .context("failed to install Ctrl+C handler")?;
+
+        // SAFETY: 
+        // This calls the `epoll_create1` syscall via libc. The function is safe to call
+        // as long as the provided flags are valid. We pass `EPOLL_CLOEXEC`, which is a
+        // valid constant. The function does not access memory through pointers.
+        // The returned file descriptor must be checked for errors (fd >= 0) before use.
+        let epfd = unsafe { libc::epoll_create1(libc::EPOLL_CLOEXEC) };
+        if epfd < 0 {
+            return Err(std::io::Error::last_os_error()).context("epoll_create1 failed");
+        }
+
+        let mut ev = libc::epoll_event {
+            events: libc::EPOLLIN as u32,
+            u64: self.uffd_fd as u64,
+        };
+
+        // SAFETY: 
+        // `epoll_ctl` is a libc syscall wrapper. We pass a valid epoll file descriptor
+        // (`epfd`) and a valid target file descriptor (`self.uffd_fd`). The pointer
+        // to `ev` is valid and points to initialized memory for the duration of the call.
+        // `epoll_ctl` does not retain the pointer after returning, so no aliasing or
+        // lifetime issues occur.
+        let ctl = unsafe {
+            libc::epoll_ctl(
+                epfd,
+                libc::EPOLL_CTL_ADD,
+                self.uffd_fd,
+                &mut ev as *mut libc::epoll_event,
+            )
+        };
+        if ctl < 0 {
+            let err = std::io::Error::last_os_error();
+            // SAFETY: 
+            // `close` is a libc syscall that does not dereference pointers. We pass a file
+            // descriptor (`epfd`) obtained from `epoll_create1`. The fd is assumed to be
+            // valid and not already closed. No further use of `epfd` occurs after this call,
+            // preventing use-after-close.
+            unsafe {
+                libc::close(epfd);
+            }
+            return Err(err).context("epoll_ctl failed");
+        }
+
+        let mut events: [libc::epoll_event; 8] = 
+            // SAFETY: 
+            // epoll_event is a plain C struct and zero-initialization is valid.
+            unsafe {
+                std::mem::zeroed()
+            };
+
+        let result = (|| -> Result<()> {
+            loop {
+                if stop.load(Ordering::SeqCst) {
+                    debug!("[handler] stop flag set, breaking loop");
+                    break;
+                }
+
+                let n = 
+                    // SAFETY: 
+                    // `epoll_wait` is a libc syscall that writes up to `events.len()` initialized
+                    // `epoll_event` entries into the provided buffer. `events.as_mut_ptr()` points
+                    // to valid, writable memory for `events.len()` elements, and the buffer lives
+                    // for the duration of the call. The length passed matches the buffer capacity,
+                    // so no out-of-bounds writes occur.
+                    unsafe {
+                        libc::epoll_wait(epfd, events.as_mut_ptr(), events.len() as i32, 100)
+                    };
+
+                if n < 0 {
+                    let err = std::io::Error::last_os_error();
+
+                    if err.kind() == std::io::ErrorKind::Interrupted {
+                        if stop.load(Ordering::SeqCst) {
+                            eprintln!("[handler] epoll interrupted and stop requested");
+                            break;
+                        }
+                        continue;
+                    }
+
+                    return Err(err).context("epoll_wait failed");
+                }
+
+                if n == 0 {
+                    continue;
+                }
+
+                for _ in 0..n {
+                    if stop.load(Ordering::SeqCst) {
+                        eprintln!("[handler] stop flag set during event processing");
+                        break;
+                    }
+
+                    // For optimization
+                    let batch = self.drain_fault_batch_opti()?;
+                    if batch.is_empty() {
+                        continue;
+                    }
+
+                    self.coalesce_and_copy_opti(&batch)?;
+                }
+
+            }
+
+            Ok(())
+        })();
+
+        // SAFETY: 
+        // `epfd` is a valid file descriptor previously returned by `epoll_create1`
+        // and has not been closed yet. Calling `close` releases the descriptor and
+        // does not violate Rust memory safety guarantees.
+        unsafe {
+            libc::close(epfd);
+        }
+
+        for idx in 0..self.heuristics.len() {
+            self.finalize_prefetch_window(idx);
+        }
+
+        eprintln!("\n[handler] exiting run(), dumping stats...");
+        self.print_stats_opti();
+        self.print_perf_summary_opti();
+
+        result
+    }
+}
+
+// change - for external UFFD (lazy loading) restore
+fn main() -> Result<()> {
+
+    let socket_path = Path::new("/tmp/uffd.sock");
+    let _ = std::fs::remove_file(socket_path);
+
+    let listener = UnixListener::bind(socket_path)?;
+    eprintln!("[handler] listening on /tmp/uffd.sock");
+    
+    let (hs, uffd_fd) = accept_and_recv_handshake(&listener)?;
+
+    eprintln!(
+        "[handler] version={} mappings={} snapshot={:?}",
+        hs.version,
+        hs.mappings.len(),
+        hs.snapshot_path
+    );
+
+    let file = File::open(&hs.snapshot_path)?;
+    let snapshot = SnapshotMap::map(&file)?;
+    eprintln!("[handler] snapshot mmap OK");
+
+    let mappings = hs.mappings;
+    let mappings_len = mappings.len();
+
+    let mut handler = ExternalUffdHandler {
+        uffd_fd,
+        snapshot,
+        mappings,
+        heuristics: vec![RegionHeuristics::default(); mappings_len],
+        stats: vec![RegionStats::default(); mappings_len],
+        handler_stats: HandlerStats::default(),
+        scratch: vec![0u8; COPY_CHUNK_BYTES as usize],
+    };
+
+    handler.run()
+}
+
+
