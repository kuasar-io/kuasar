+    // Change - For file-backend MMAP restore
+    fn register_guest_memory_regions_with_hypervisor(
+        vm: &Arc<dyn hypervisor::Vm>,
+        guest_memory: &GuestMemoryMmap,
+        guest_ram_mappings: &[GuestRamMapping],
+        log_dirty: bool,
+    ) -> Result<(), Error> {
+        for m in guest_ram_mappings {
+            let region = guest_memory
+                .find_region(GuestAddress(m.gpa))
+                .ok_or(Error::MissingGuestRegionForMapping)?;
+
+            if region.len() != m.size {
+                return Err(Error::RestoredRegionSizeMismatch);
+            }
+
+            let region_addr = region
+                .to_region_addr(GuestAddress(m.gpa))
+                .ok_or(Error::MissingGuestRegionForMapping)?;
+
+            let host_addr = region
+                .get_host_address(region_addr)
+                .map_err(Error::GuestMemoryAccess)?;
+
+            debug!(
+                "register memory slot: slot={}, gpa=0x{:x}, size=0x{:x}, host_addr={:p}, log_dirty={}",
+                m.slot,
+                m.gpa,
+                m.size,
+                host_addr,
+                log_dirty
+            );
+
+            // SAFETY:
+            // We pass a valid userspace memory region to the hypervisor. The `host_addr`
+            // is derived from a mapped GuestMemory region and remains valid for the
+            // lifetime of the VM. The size and guest physical address (`gpa`) correspond
+            // to the snapshot layout and are page-aligned. No aliasing or overlapping
+            // regions are introduced, and the memory is not freed while the VM is using it.
+            //
+            // host_addr points into a mmap'ed snapshot file that stays mapped for the
+            // entire VM lifetime.
+            unsafe {
+                vm.create_user_memory_region(
+                    m.slot,
+                    m.gpa,
+                    m.size as usize,
+                    host_addr,
+                    log_dirty,
+                    false,
+                )
+                .map_err(Error::CreateUserMemoryRegion)?;
+            }
+
+            if region.start_addr().raw_value() != m.gpa {
+                return Err(Error::RestoredRegionSizeMismatch);
+            }
+        }
+
+        Ok(())
+    }
