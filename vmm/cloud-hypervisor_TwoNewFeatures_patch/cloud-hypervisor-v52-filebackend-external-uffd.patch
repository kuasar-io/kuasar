+    // for external UFFD optimization
+    fn coalesce_and_copy_opti(&mut self, batch: &[PendingFault]) -> Result<()> {
+        if batch.is_empty() {
+            return Ok(());
+        }
+
+        let batch_faults = batch.len() as u64;
+        if batch_faults > self.handler_stats.max_faults_in_batch {
+            self.handler_stats.max_faults_in_batch = batch_faults;
+        }
+
+        let mut ranges = self.merge_faults_into_ranges(batch.to_vec());
+
+        self.handler_stats.batch_count += 1;
+        self.handler_stats.drained_faults_total += batch_faults;
+
+
+        for range in &mut ranges {
+            self.maybe_expand_range_with_prefetch(range);
+        }
+
+        for range in &ranges {
+            let idx = range.mapping_idx;
+            let page_size = self.mappings[idx].page_size;
+            let pages_in_range = range.total_pages(page_size);
+
+            self.stats[idx].batch_count += 1;
+            self.stats[idx].drained_faults += range.fault_pages;
+            self.stats[idx].merged_ranges += 1;
+
+            if range.fault_pages > 1 {
+                self.stats[idx].merged_fault_savings += range.fault_pages - 1;
+            }
+
+            if pages_in_range > self.handler_stats.max_pages_in_batch {
+                self.handler_stats.max_pages_in_batch = pages_in_range;
+            }
+
+            self.handler_stats.merged_ranges += 1;
+            if range.fault_pages > 1 {
+                self.handler_stats.merged_fault_savings += range.fault_pages - 1;
+            }
+
+            self.copy_range_from_snapshot(range)?;
+        }
+
+        Ok(())
+    }
+
+    fn copy_one_page(&self, dst: u64, src: u64, page_size: u64) -> Result<PageCopyResult> {
+        let mut eagain_retries = 0u32;
+
+        loop {
+            let mut copy = uffdio_copy {
+                dst,
+                src,
+                len: page_size,
+                mode: 0,
+                copy: 0,
+            };
+
+            // SAFETY: 
+            // `self.uffd_fd` is a valid userfaultfd file descriptor. `copy` is a valid
+            // and initialized `uffdio_copy` value whose dst/src/len fields describe
+            // page-aligned memory ranges prepared by the handler. Passing `&mut copy` is
+            // safe because the kernel may write the result back into the structure, and
+            // the structure remains alive for the duration of the ioctl call.
+            let ret = unsafe { ioctl(self.uffd_fd, UFFDIO_COPY, &mut copy) };
+            if ret == 0 {
+                return Ok(PageCopyResult::Copied);
+            }
+
+            let err = io::Error::last_os_error();
+            match err.raw_os_error() {
+                Some(libc::EEXIST) => {
+                    eprintln!(
+                        "[handler] page already present: dst=0x{dst:x} src=0x{src:x} len=0x{page_size:x}"
+                    );
+                    return Ok(PageCopyResult::AlreadyPresent);
+                }
+                Some(libc::EAGAIN) if eagain_retries < 50 => {
+                    eagain_retries += 1;
+                    std::thread::yield_now();
+                }
+                _ => {
+                    return Err(err).context("UFFDIO_COPY page failed");
+                }
+            }
+        }
+    }
+
+    fn copy_range(&self, dst: u64, src: u64, len: u64, page_size: u64) -> Result<CopyStats> {
+        let attempted_pages = len / page_size;
+
+        let mut stats = CopyStats {
+            outcome: CopyOutcome::Full,
+            attempted_pages,
+            copied_pages: 0,
+            skipped_existing_pages: 0,
+            eagain_retries: 0,
+            range_copy_calls: 1,
+            page_copy_calls: 0,
+        };
+
+        let mut copy = uffdio_copy {
+            dst,
+            src,
+            len,
+            mode: 0,
+            copy: 0,
+        };
+
+        // SAFETY: 
+        // `self.uffd_fd` is a valid userfaultfd file descriptor. `copy` is a valid
+        // and initialized `uffdio_copy` value whose dst/src/len fields describe
+        // page-aligned memory ranges prepared by the handler. Passing `&mut copy` is
+        // safe because the kernel may write the result back into the structure, and
+        // the structure remains alive for the duration of the ioctl call.
+        let ret = unsafe { ioctl(self.uffd_fd, UFFDIO_COPY, &mut copy) };
+        if ret == 0 {
+            stats.copied_pages = attempted_pages;
+            return Ok(stats);
+        }
+
+        let err = io::Error::last_os_error();
+        let mut fallback_needed = false;
+        let mut had_eagain = false;
+
+        match err.raw_os_error() {
+            Some(libc::EAGAIN) => {
+                had_eagain = true;
+
+                for _ in 0..50 {
+                    stats.eagain_retries += 1;
+                    std::thread::yield_now();
+
+                    let mut retry_copy = uffdio_copy {
+                        dst,
+                        src,
+                        len,
+                        mode: 0,
+                        copy: 0,
+                    };
+
+                    // SAFETY: 
+                    // `self.uffd_fd` is a valid userfaultfd file descriptor. `retry_copy` is a
+                    // properly initialized `uffdio_copy` structure with page-aligned dst/src/len
+                    // describing a valid memory range prepared earlier. This is a retry of a
+                    // previous UFFDIO_COPY, and the underlying memory mappings remain valid and
+                    // unchanged. Passing `&mut retry_copy` is safe because the kernel may write
+                    // result fields back into the structure, and it lives for the duration of
+                    // the ioctl call.
+                    let retry_ret = unsafe { ioctl(self.uffd_fd, UFFDIO_COPY, &mut retry_copy) };
+                    if retry_ret == 0 {
+                        stats.outcome = CopyOutcome::EagainRetry;
+                        stats.copied_pages = attempted_pages;
+                        return Ok(stats);
+                    }
+
+                    let retry_err = io::Error::last_os_error();
+                    match retry_err.raw_os_error() {
+                        Some(libc::EAGAIN) => {
+                            continue;
+                        }
+                        Some(libc::EEXIST) => {
+                            fallback_needed = true;
+                            break;
+                        }
+                        _ => {
+                            return Err(retry_err).context("UFFDIO_COPY range retry failed");
+                        }
+                    }
+                }
+
+                if !fallback_needed {
+                    fallback_needed = true;
+                }
+            }
+            Some(libc::EEXIST) => {
+                fallback_needed = true;
+            }
+            _ => {
+                return Err(err).context("UFFDIO_COPY range failed");
+            }
+        }
+
+        if fallback_needed {
+            eprintln!(
+                "[handler] range copy fallback to per-page: dst=0x{dst:x} src=0x{src:x} len=0x{len:x}"
+            );
+
+            let mut off = 0u64;
+            while off < len {
+                stats.page_copy_calls += 1;
+
+                match self.copy_one_page(dst + off, src + off, page_size)? {
+                    PageCopyResult::Copied => {
+                        stats.copied_pages += 1;
+                    }
+                    PageCopyResult::AlreadyPresent => {
+                        stats.skipped_existing_pages += 1;
+                    }
+                }
+
+                off += page_size;
+            }
+
+            stats.outcome = CopyOutcome::Fallback;
+            if had_eagain {
+                // 仍然归类为 Fallback，因为最终走了 fallback 路径
+                stats.outcome = CopyOutcome::Fallback;
+            }
+
+            return Ok(stats);
+        }
+
+        Ok(stats)
+    }
+
+    #[allow(unused)]
