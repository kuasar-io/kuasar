--- /dev/null
+++ b/vmm/src/external_uffd.rs
@@ -0,0 +1,619 @@
+// Copyright 2026 The Kuasar Authors
+// 
+// SPDX-License-Identifier: Apache-2.0
+//
+// 1. Imports（放最顶部）
+use serde::{Deserialize, Serialize};
+use std::io;
+use std::mem::{size_of, zeroed};
+use std::os::fd::{AsRawFd, RawFd};
+use std::os::unix::net::{UnixStream,UnixListener};
+use std::path::{Path, PathBuf};
+use std::fs::File;
+
+// 2. protocol（握手层
+// ======================
+// protocol
+// ======================
+pub const EXTERNAL_UFFD_HANDSHAKE_VERSION: u16 = 1;
+const CONTROL_BUF_SIZE: usize = 64;
+
+pub const EXTERNAL_UFFD_EVENT_PAGEFAULT: u8 = crate::userfaultfd::UFFD_EVENT_PAGEFAULT;
+
+#[derive(Clone, Debug, Serialize, Deserialize)]
+pub struct ExternalUffdHandshake {
+    pub version: u16,
+    pub snapshot_path: PathBuf,
+    pub mappings: Vec<ExternalUffdMapping>,
+}
+
+#[derive(Clone, Debug, Serialize, Deserialize)]
+pub struct ExternalUffdMapping {
+    pub base_host_virt_addr: u64,
+    pub size: u64,
+    pub offset: u64,
+    pub page_size: u64,
+    pub gpa: u64,
+    pub zone_id: Option<String>,
+}
+
+// 5. runtime mapping（核心逻辑层）
+// ======================
+// runtime mapping
+// ======================
+#[derive(Debug, Clone)]
+pub struct RegionTable {
+    mappings: Vec<ExternalUffdMapping>,
+}
+
+// Change - for external UFFD (lazy loading) restore
+// For external handler
+#[derive(Debug, Clone)]
+pub struct ResolvedFault {
+    pub fault_addr: u64,
+    pub page_addr: u64,
+    pub file_offset: u64,
+    pub mapping_index: usize,
+}
+
+union ControlBuf {
+    buf: [u8; CONTROL_BUF_SIZE],
+}
+
+// Change - For external UFFD (lazy loading) restore
+// For external handler
+impl RegionTable {
+    pub fn new(mut mappings: Vec<ExternalUffdMapping>) -> io::Result<Self> {
+        if mappings.is_empty() {
+            return Err(io::Error::new(
+                io::ErrorKind::InvalidInput,
+                "empty mappings",
+            ));
+        }
+
+        // 排序（非常重要）
+        mappings.sort_by_key(|m| m.base_host_virt_addr);
+
+        // 校验（强烈建议）
+        for m in &mappings {
+            if m.size == 0 {
+                return Err(io::Error::new(
+                    io::ErrorKind::InvalidData,
+                    "mapping size must be > 0",
+                ));
+            }
+
+            if m.page_size == 0 {
+                return Err(io::Error::new(
+                    io::ErrorKind::InvalidData,
+                    "page_size must be > 0",
+                ));
+            }
+
+            if m.base_host_virt_addr % m.page_size != 0
+                || m.size % m.page_size != 0
+                || m.offset % m.page_size != 0
+            {
+                return Err(io::Error::new(
+                    io::ErrorKind::InvalidData,
+                    "mapping not page aligned",
+                ));
+            }
+        }
+
+        // overlap 检查
+        for pair in mappings.windows(2) {
+            let a = &pair[0];
+            let b = &pair[1];
+
+            let a_end = a.base_host_virt_addr + a.size;
+
+            if a_end > b.base_host_virt_addr {
+                return Err(io::Error::new(
+                    io::ErrorKind::InvalidData,
+                    "overlapping mappings",
+                ));
+            }
+        }
+
+        Ok(Self { mappings })
+    }
+
+    // Change - for external UFFD (lazy loading) restore
+    // for external handler
+    pub fn resolve_fault(&self, fault_addr: u64) -> io::Result<ResolvedFault> {
+        for (idx, m) in self.mappings.iter().enumerate() {
+            let start = m.base_host_virt_addr;
+            let end = m.base_host_virt_addr + m.size;
+
+            if fault_addr >= start && fault_addr < end {
+                let page_size = m.page_size;
+
+                let page_addr = fault_addr - (fault_addr % page_size);
+
+                let delta = page_addr - start;
+                let file_offset = m.offset + delta;
+
+                eprintln!(
+                        "[handler] resolve: addr=0x{fault_addr:x} page_addr=0x{page_addr:x} -> mapping_idx={idx} offset=0x{file_offset:x}"
+                    );
+
+                return Ok(ResolvedFault {
+                    fault_addr,
+                    page_addr,
+                    file_offset,
+                    mapping_index: idx,
+                });
+            }
+        }
+
+        Err(io::Error::new(
+            io::ErrorKind::NotFound,
+            format!("fault addr {fault_addr:#x} not covered by any mapping"),
+        ))
+    }
+
+    pub fn find_mapping_by_addr(&self, addr: u64) -> Option<(usize, &ExternalUffdMapping)> {
+        self.mappings
+            .iter()
+            .enumerate()
+            .find(|(_, m)| {
+                addr >= m.base_host_virt_addr
+                    && addr < m.base_host_virt_addr.saturating_add(m.size)
+            })
+    }
+
+    pub fn validate(&self) -> anyhow::Result<()> {
+        for (i, m) in self.mappings.iter().enumerate() {
+            if m.size == 0 {
+                anyhow::bail!("mapping[{i}] has zero size");
+            }
+            if m.page_size == 0 {
+                anyhow::bail!("mapping[{i}] has zero page_size");
+            }
+            if m.base_host_virt_addr % m.page_size != 0 {
+                anyhow::bail!(
+                    "mapping[{}] base_host_virt_addr 0x{:x} not aligned to page_size {}",
+                    i,
+                    m.base_host_virt_addr,
+                    m.page_size
+                );
+            }
+            if m.offset % m.page_size != 0 {
+                anyhow::bail!(
+                    "mapping[{}] offset 0x{:x} not aligned to page_size {}",
+                    i,
+                    m.offset,
+                    m.page_size
+                );
+            }
+            if m.size % m.page_size != 0 {
+                anyhow::bail!(
+                    "mapping[{}] size 0x{:x} not multiple of page_size {}",
+                    i,
+                    m.size,
+                    m.page_size
+                );
+            }
+        }
+        Ok(())
+    }
+}
+
+// 4. handshake helpers（sender / receiver 对称）
+// ======================
+// handshake helpers
+// ======================
+// Change - For external UFFD (lazy loading) restore
+// For external handler side
+pub fn connect_and_send_handshake(
+    socket_path: &Path,
+    hs: &ExternalUffdHandshake,
+    uffd_fd: RawFd,
+) -> io::Result<()> {
+    let sock = UnixStream::connect(socket_path)?;
+    let payload = serde_json::to_vec(hs).map_err(io::Error::other)?;
+    send_with_fd(sock.as_raw_fd(), &payload, uffd_fd)
+}
+
+// Change - For external UFFD
+// For external handler side
+pub fn accept_and_recv_handshake(
+    listener: &UnixListener,
+) -> io::Result<(ExternalUffdHandshake, RawFd)> {
+    let (stream, _) = listener.accept()?;
+
+    let (payload, uffd_fd) = recv_with_fd(stream.as_raw_fd())?;
+
+    let hs: ExternalUffdHandshake = serde_json::from_slice(&payload)
+        .map_err(|e| io::Error::new(io::ErrorKind::InvalidData, e))?;
+
+    if hs.version != EXTERNAL_UFFD_HANDSHAKE_VERSION {
+        return Err(io::Error::new(
+            io::ErrorKind::InvalidData,
+            format!("unsupported handshake version: {}", hs.version),
+        ));
+    }
+
+    Ok((hs, uffd_fd))
+}
+// ======================
+// 3, fd passing
+// ======================
+//
+// send_with_fd(...)
+// recv_with_fd(...)
+//
+// Change - for external UFFD (lazy loading) restore 
+// For external handler side
+pub fn send_with_fd(sock_fd: RawFd, data: &[u8], fd: RawFd) -> io::Result<()> {
+    let mut iov = libc::iovec {
+        iov_base: data.as_ptr() as *mut libc::c_void,
+        iov_len: data.len(),
+    };
+
+    let fd_size = size_of::<RawFd>() as u32;
+
+    // SAFETY: CMSG_SPACE only computes the required buffer size for ancillary data.
+    // It does not dereference pointers or access memory. `fd_size` is a valid length.
+    let control_len = unsafe { libc::CMSG_SPACE(fd_size) as usize };
+
+    // This fixed-size buffer is intentionally aligned as `cmsghdr` by the union.
+    let mut control =
+        // SAFETY: Initializing the `buf` field with zeroed bytes is valid.
+        // The union is used as raw storage, and we will treat it as a byte buffer
+        // for constructing ancillary data.
+        unsafe {
+            std::mem::zeroed::<ControlBuf>()
+        };
+
+    assert!(
+        control_len <= 64,
+        "control buffer too small: need {control_len} bytes"
+    );
+
+    let control_ptr =
+        // SAFETY: Accessing the `buf` field is safe here because we are treating the
+        // union storage as a raw byte buffer for ancillary data construction.
+        unsafe {
+            control.buf.as_mut_ptr()
+        };
+
+    debug_assert_eq!(
+        (control_ptr as usize) % std::mem::align_of::<libc::cmsghdr>(),
+        0,
+        "control buffer is not properly aligned for cmsghdr"
+    );
+
+    let mut msg: libc::msghdr =
+        // SAFETY: `libc::msghdr` is a plain C struct for which zero-initialization is valid.
+        // Null pointers and zero lengths form a valid initial state, and required fields are
+        // set before the syscall.
+        unsafe { zeroed() };
+
+    msg.msg_iov = &mut iov;
+    msg.msg_iovlen = 1;
+    msg.msg_control = control_ptr as *mut libc::c_void;
+    msg.msg_controllen = control_len;
+
+    // SAFETY:
+    // - `msg.msg_control` points to a writable ancillary-data buffer aligned for `cmsghdr`.
+    // - The buffer is at least `CMSG_SPACE(sizeof(RawFd))` bytes long.
+    // - `CMSG_FIRSTHDR(&msg)` is checked for null before dereference.
+    // - We initialize exactly one `cmsghdr` for `SOL_SOCKET/SCM_RIGHTS`.
+    // - `CMSG_DATA(cmsg)` points to space sufficient for one `RawFd`, matching `CMSG_LEN(fd_size)`.
+    unsafe {
+        let cmsg = libc::CMSG_FIRSTHDR(&msg);
+        if cmsg.is_null() {
+            return Err(io::Error::other("CMSG_FIRSTHDR returned null"));
+        }
+
+        let cmsg_len = libc::CMSG_LEN(fd_size) as usize;
+
+        (*cmsg).cmsg_level = libc::SOL_SOCKET;
+        (*cmsg).cmsg_type = libc::SCM_RIGHTS;
+        (*cmsg).cmsg_len = cmsg_len;
+
+        debug_assert_eq!((*cmsg).cmsg_level, libc::SOL_SOCKET);
+        debug_assert_eq!((*cmsg).cmsg_type, libc::SCM_RIGHTS);
+        debug_assert_eq!((*cmsg).cmsg_len, cmsg_len);
+        debug_assert!(control_len >= cmsg_len);
+        debug_assert!(cmsg_len >= size_of::<libc::cmsghdr>());
+
+        let data_ptr = libc::CMSG_DATA(cmsg) as *mut RawFd;
+
+        debug_assert_eq!(
+            (data_ptr as usize) % std::mem::align_of::<RawFd>(),
+            0,
+            "CMSG_DATA is not properly aligned for RawFd"
+        );
+
+        *data_ptr = fd;
+    }
+
+    // SAFETY:
+    // - `sock_fd` is assumed to be a valid socket fd supplied by the caller.
+    // - `msg` is fully initialized.
+    // - `iov` and ancillary control storage remain alive for the duration of the call.
+    let ret = unsafe { libc::sendmsg(sock_fd, &msg, 0) };
+
+    if ret < 0 {
+        return Err(io::Error::last_os_error());
+    }
+
+    if ret as usize != data.len() {
+        return Err(io::Error::new(
+            io::ErrorKind::WriteZero,
+            format!("short sendmsg: sent {ret} bytes, expected {}", data.len()),
+        ));
+    }
+
+    Ok(())
+}
+
+// Change - For external UFFD (lazy loading) restore
+// For external handler side
+pub fn recv_with_fd(sock_fd: RawFd) -> io::Result<(Vec<u8>, RawFd)> {
+    let mut data = vec![0u8; 4096];
+
+    let mut iov = libc::iovec {
+        iov_base: data.as_mut_ptr() as *mut libc::c_void,
+        iov_len: data.len(),
+    };
+
+    let fd_size = size_of::<RawFd>() as u32;
+
+    // SAFETY: CMSG_SPACE only computes the ancillary buffer size for one fd.
+    // It does not dereference pointers or access memory.
+    let control_len = unsafe { libc::CMSG_SPACE(fd_size) as usize };
+
+    if control_len > CONTROL_BUF_SIZE {
+        return Err(io::Error::other(format!(
+            "control buffer too small: need {control_len}, have {CONTROL_BUF_SIZE}"
+        )));
+    }
+
+    let mut control =
+        // SAFETY: ControlBuf is used as raw aligned storage for ancillary data.
+        // Zero initialization is valid because both fields are plain C-compatible data
+        unsafe {
+            zeroed::<ControlBuf>()
+    };
+
+    let control_ptr = 
+        // SAFETY: We access the union byte field only as raw backing storage for
+        // ancillary data, relying on the union for proper cmsghdr alignment.
+        unsafe {
+        control.buf.as_mut_ptr()
+    };
+
+    let mut msg: libc::msghdr =
+        // SAFETY: msghdr is a plain C struct where zero initialization is valid.
+        // Required fields are initialized before recvmsg.
+        unsafe {
+            zeroed()
+    };
+
+    msg.msg_iov = &mut iov;
+    msg.msg_iovlen = 1;
+    msg.msg_control = control_ptr as *mut libc::c_void;
+    msg.msg_controllen = control_len;
+
+    let ret =
+        // SAFETY:
+        // - sock_fd is assumed to be a valid Unix-domain socket fd from the caller.
+        // - msg points to valid writable payload and ancillary buffers for the duration
+        //   of the syscall.
+        unsafe {
+            libc::recvmsg(sock_fd, &mut msg, 0)
+    };
+
+    if ret < 0 {
+        return Err(io::Error::last_os_error());
+    }
+
+    let data_len = ret as usize;
+    data.truncate(data_len);
+
+    if (msg.msg_flags & libc::MSG_CTRUNC) != 0 {
+        return Err(io::Error::other("ancillary data was truncated"));
+    }
+
+    let received_fd =
+         // SAFETY:
+        // - msg.msg_control points to a valid ancillary-data buffer filled by recvmsg.
+        // - We check each cmsghdr pointer for null before dereferencing.
+        // - We only read a RawFd from CMSG_DATA when the header is for SOL_SOCKET /
+        //   SCM_RIGHTS and cmsg_len is large enough to contain one RawFd.
+        unsafe {
+            let mut cmsg = libc::CMSG_FIRSTHDR(&msg);
+
+            while !cmsg.is_null() {
+                if (*cmsg).cmsg_level == libc::SOL_SOCKET
+                    && (*cmsg).cmsg_type == libc::SCM_RIGHTS
+                {
+                    let min_len = libc::CMSG_LEN(fd_size) as usize;
+                    if (*cmsg).cmsg_len < min_len {
+                        return Err(io::Error::other(format!(
+                            "SCM_RIGHTS control message too short: got {}, need at least {}",
+                            (*cmsg).cmsg_len,
+                            min_len
+                        )));
+                    }
+
+                    let data_ptr = libc::CMSG_DATA(cmsg) as *const RawFd;
+
+                    debug_assert_eq!(
+                        (data_ptr as usize) % std::mem::align_of::<RawFd>(),
+                        0,
+                        "CMSG_DATA not aligned for RawFd"
+                    );
+
+                    let fd = *data_ptr;
+                    if fd < 0 {
+                        return Err(io::Error::other(format!(
+                            "received invalid fd: {fd}"
+                        )));
+                    }
+
+                    return Ok((data, fd));
+                }
+
+                cmsg = libc::CMSG_NXTHDR(&msg, cmsg);
+            }
+
+            Err(io::Error::other("did not receive SCM_RIGHTS fd"))
+        }?;
+
+    Ok((data, received_fd))
+}
+
+// Change - for external UFFD (lazy loading) restore
+// For external handler side
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::os::fd::RawFd;
+
+    #[test]
+    fn test_send_and_recv_fd() -> io::Result<()> {
+        let mut sv = [0 as RawFd; 2];
+        let rc = unsafe {
+            // SAFETY: `sv` points to space for two fds as required by socketpair.
+            libc::socketpair(libc::AF_UNIX, libc::SOCK_STREAM, 0, sv.as_mut_ptr())
+        };
+        if rc < 0 {
+            return Err(io::Error::last_os_error());
+        }
+
+        let sender = sv[0];
+        let receiver = sv[1];
+
+        let mut pipefds = [0 as RawFd; 2];
+        let rc = unsafe {
+            // SAFETY: `pipefds` points to space for two fds as required by pipe.
+            libc::pipe(pipefds.as_mut_ptr())
+        };
+        if rc < 0 {
+            unsafe {
+                libc::close(sender);
+                libc::close(receiver);
+            }
+            return Err(io::Error::last_os_error());
+        }
+
+        let read_fd = pipefds[0];
+        let write_fd = pipefds[1];
+
+        let payload = b"hello-fd";
+
+        send_with_fd(sender, payload, write_fd)?;
+
+        let (received_payload, received_fd) = recv_with_fd(receiver)?;
+
+        assert_eq!(received_payload, payload);
+
+        let msg = b"ping-through-passed-fd";
+        let write_rc = unsafe {
+            // SAFETY: `received_fd` is expected to be a valid writable pipe fd,
+            // and `msg` points to readable memory of length `msg.len()`.
+            libc::write(
+                received_fd,
+                msg.as_ptr() as *const libc::c_void,
+                msg.len(),
+            )
+        };
+        assert_eq!(write_rc as usize, msg.len());
+
+        let mut buf = vec![0u8; msg.len()];
+        let read_rc = unsafe {
+            // SAFETY: `read_fd` is expected to be a valid readable pipe fd,
+            // and `buf` points to writable memory of length `buf.len()`.
+            libc::read(
+                read_fd,
+                buf.as_mut_ptr() as *mut libc::c_void,
+                buf.len(),
+            )
+        };
+        assert_eq!(read_rc as usize, msg.len());
+        assert_eq!(buf, msg);
+
+        unsafe {
+            // SAFETY: These are raw fds created in this test and not yet closed.
+            libc::close(sender);
+            libc::close(receiver);
+            libc::close(read_fd);
+            libc::close(write_fd);
+            libc::close(received_fd);
+        }
+
+        Ok(())
+    }
+}
