+    // Optimization version
+    fn drain_fault_batch_opti(&mut self) -> Result<Vec<PendingFault>> {
+        let first = match self.read_one_fault_nonblocking()? {
+            Some(f) => f,
+            None => return Ok(Vec::new()),
+        };
+
+        let mut faults = Vec::with_capacity(MAX_BATCHED_FAULTS);
+        faults.push(first);
+
+        for _ in 0..MAX_DRAIN_PER_WAKE {
+            if faults.len() >= MAX_BATCHED_FAULTS {
+                break;
+            }
+
+            match self.read_one_fault_nonblocking()? {
+                Some(f) => faults.push(f),
+                None => break,
+            }
+        }
+
+        for _ in 0..DRAIN_SPIN_ROUNDS {
+            if faults.len() >= MAX_BATCHED_FAULTS {
+                break;
+            }
+
+            std::hint::spin_loop();
+
+            #[allow(clippy::single_match)]
+            match self.read_one_fault_nonblocking()? {
+                Some(f) => faults.push(f),
+                None => {}
+            }
+        }
+
+        Ok(faults)
+    }
