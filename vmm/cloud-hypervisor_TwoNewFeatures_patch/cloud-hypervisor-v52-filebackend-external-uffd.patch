+impl ExternalUffdHandler {
+    fn finalize_prefetch_window(&mut self, mapping_idx: usize) {
+        let heur = &mut self.heuristics[mapping_idx];
+        let wasted = heur.prefetched_pages_outstanding;
+
+        if wasted > 0 {
+            self.handler_stats.prefetch_wasted_pages += wasted;
+            heur.prefetched_pages_outstanding = 0;
+        }
+
+        heur.prefetch_start = 0;
+        heur.prefetch_end = 0;
+    }
+
+    fn record_prefetch_hit_if_any(&mut self, mapping_idx: usize, fault_addr: u64) {
+        let heur = &mut self.heuristics[mapping_idx];
+
+        if heur.prefetch_start == 0 || heur.prefetch_end == 0 {
+            return;
